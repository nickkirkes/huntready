# =============================================================================
# HuntReady — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore and must NEVER be committed.
#
# All Supabase values are found in your Supabase Dashboard:
#   Project Settings > API Keys (publishable + secret keys)
#   Project Settings > Database (connection string)

# --- Supabase ---

# Supabase project URL
# Used by: MCP server, web app
SUPABASE_URL=

# Supabase secret key (full access, bypasses RLS)
# Used by: MCP server, ingestion pipeline
# Keep secret — never expose to client-side code
# Dashboard: API Keys > Secret keys
SUPABASE_SECRET_KEY=

# Supabase publishable key (public, scoped by RLS policies)
# Used by: web app
# Dashboard: API Keys > Publishable key
SUPABASE_PUBLISHABLE_KEY=

# Direct Postgres connection string
# Used by: ingestion pipeline, database migrations ONLY
# NOT used by the serving stack (MCP server, web app) — see ADR-003
DATABASE_URL=

# --- Mapbox ---

# Mapbox GL JS access token (needed at M4 for web map)
# Get from your Mapbox account dashboard
MAPBOX_ACCESS_TOKEN=
